<Application x:Class="WoodInventory.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers">
    <Application.Resources>
        <ResourceDictionary>

            <helpers:RowNumberConverter x:Key="RowNumberConverter"/>

            <!-- ======= Bảng màu (Tailwind slate/blue/emerald/rose) — khớp bản web ======= -->
            <SolidColorBrush x:Key="Slate50"  Color="#F8FAFC"/>
            <SolidColorBrush x:Key="Slate100" Color="#F1F5F9"/>
            <SolidColorBrush x:Key="Slate150" Color="#E9EEF4"/>
            <SolidColorBrush x:Key="Slate200" Color="#E2E8F0"/>
            <SolidColorBrush x:Key="Slate300" Color="#CBD5E1"/>
            <SolidColorBrush x:Key="Slate400" Color="#94A3B8"/>
            <SolidColorBrush x:Key="Slate500" Color="#64748B"/>
            <SolidColorBrush x:Key="Slate600" Color="#475569"/>
            <SolidColorBrush x:Key="Slate700" Color="#334155"/>
            <SolidColorBrush x:Key="Slate800" Color="#1E293B"/>
            <SolidColorBrush x:Key="Slate900" Color="#0F172A"/>
            <SolidColorBrush x:Key="Slate950" Color="#020617"/>

            <SolidColorBrush x:Key="Blue50"  Color="#EFF6FF"/>
            <SolidColorBrush x:Key="Blue100" Color="#DBEAFE"/>
            <SolidColorBrush x:Key="Blue200" Color="#BFDBFE"/>
            <SolidColorBrush x:Key="Blue300" Color="#93C5FD"/>
            <SolidColorBrush x:Key="Blue400" Color="#60A5FA"/>
            <SolidColorBrush x:Key="Blue500" Color="#3B82F6"/>
            <SolidColorBrush x:Key="Blue600" Color="#2563EB"/>
            <SolidColorBrush x:Key="Blue700" Color="#1D4ED8"/>
            <SolidColorBrush x:Key="Blue800" Color="#1E40AF"/>
            <SolidColorBrush x:Key="BlueSoft" Color="#F5F9FF"/>

            <SolidColorBrush x:Key="Emerald50"  Color="#ECFDF5"/>
            <SolidColorBrush x:Key="Emerald100" Color="#D1FAE5"/>
            <SolidColorBrush x:Key="Emerald200" Color="#A7F3D0"/>
            <SolidColorBrush x:Key="Emerald500" Color="#10B981"/>
            <SolidColorBrush x:Key="Emerald600" Color="#059669"/>

            <SolidColorBrush x:Key="Indigo50"  Color="#EEF2FF"/>
            <SolidColorBrush x:Key="Indigo600" Color="#4F46E5"/>

            <SolidColorBrush x:Key="Amber500" Color="#F59E0B"/>
            <SolidColorBrush x:Key="Amber600" Color="#D97706"/>

            <SolidColorBrush x:Key="Rose50"  Color="#FFF1F2"/>
            <SolidColorBrush x:Key="Rose100" Color="#FFE4E6"/>
            <SolidColorBrush x:Key="Rose200" Color="#FECDD3"/>
            <SolidColorBrush x:Key="Rose300" Color="#FDA4AF"/>
            <SolidColorBrush x:Key="Rose400" Color="#FB7185"/>
            <SolidColorBrush x:Key="Rose500" Color="#F43F5E"/>
            <SolidColorBrush x:Key="Rose600" Color="#E11D48"/>

            <!-- Sidebar tối -->
            <SolidColorBrush x:Key="SideBg"     Color="#0F172A"/>
            <SolidColorBrush x:Key="SideBorder" Color="#1E293B"/>
            <SolidColorBrush x:Key="SideHover"  Color="#1E293B"/>

            <FontFamily x:Key="FontMono">Consolas</FontFamily>
            <FontFamily x:Key="FontSans">Segoe UI</FontFamily>

            <!-- ======= Kiểu chữ ======= -->
            <Style x:Key="THead" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource Slate500}"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource Slate500}"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- ======= Nút "x" xóa nội dung ô search (đặt bên phải, gắn ClearBox.Target = SearchBox) ======= -->
            <Style x:Key="SearchClearBtn" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Width="20" Height="20" CornerRadius="10" Background="Transparent">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                           Foreground="{StaticResource Slate400}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate200}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Ô dữ liệu DataGrid: cắt "..." khi tràn + hover hiện đầy đủ (base cho mọi ElementStyle cột) ======= -->
            <Style x:Key="GridCellText" TargetType="TextBlock">
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
            </Style>

            <!-- ======= Card (rounded-xl border slate-200) ======= -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <!-- ======= Nút chính (bg-blue-600, hover blue-700) ======= -->
            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Blue600}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Blue700}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Nút hành động phụ nền xanh lá (vd "Sao chép tạo mới") — khác hẳn Blue của nút chính ======= -->
            <Style x:Key="BtnCopy" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Emerald500}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Emerald600}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Nút viền (border slate-200, hover slate-50) ======= -->
            <Style x:Key="BtnGhost" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Nút link chữ xanh ======= -->
            <Style x:Key="BtnLink" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Blue500}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ======= Nút icon nhỏ (thao tác trong bảng) ======= -->
            <Style x:Key="BtnIcon" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="BtnIconDanger" TargetType="Button" BasedOn="{StaticResource BtnIcon}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource Rose600}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ======= Ô nhập liệu bo góc ======= -->
            <Style x:Key="Input" TargetType="TextBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <!-- MainWindow đặt TextFormattingMode="Display" (pixel-snap) toàn app cho chữ sắc nét hơn, nhưng
                     kiểu này xung đột với các bộ gõ tiếng Việt kiểu keystroke (Unikey/EVKey — swallow phím gốc rồi
                     SendInput lại) khiến nội dung gõ hiển thị lệch vị trí so với placeholder. Ô nhập liệu đổi
                     riêng về "Ideal" (đo lường chính xác, không pixel-snap) để tránh lỗi này. -->
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <!-- Padding phải đặt TRÊN CHÍNH ScrollViewer (không phải Margin của nó, cũng không
                                     phải Padding của Border cha) — TextBox nội bộ dựa vào Padding của chính
                                     PART_ContentHost để tính toán cuộn-theo-con-trỏ. Đặt sai chỗ (từng thử Margin
                                     trên ScrollViewer, rồi Padding trên Border cha) gây lệch vị trí chữ khi gõ
                                     bằng bộ gõ tiếng Việt kiểu keystroke (Unikey/EVKey) hoặc khi text tràn/cuộn. -->
                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Blue500}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Ô nhập trong bảng (nhỏ gọn hơn) — Height cố định để khớp đúng ComboBox (Select, cũng 32) cùng hàng -->
            <Style x:Key="CellInput" TargetType="TextBox" BasedOn="{StaticResource Input}">
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="Height" Value="32"/>
            </Style>
            <Style x:Key="CellInputMono" TargetType="TextBox" BasedOn="{StaticResource CellInput}">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            </Style>

            <!-- ======= Text chỉ-đọc nhưng CHỌN & COPY được (dùng cho dialog xem chi tiết) ======= -->
            <Style x:Key="CopyableText" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="IBeam"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Cảnh báo đỏ dưới field (thay MessageBox nhập thiếu) ======= -->
            <Style x:Key="FieldWarn" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource Rose600}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,5,0,0"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <!-- ======= ComboBox bo góc ======= -->
            <Style x:Key="SelectItem" TargetType="ComboBoxItem">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate100}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Blue50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Select" TargetType="ComboBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="ItemContainerStyle" Value="{StaticResource SelectItem}"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                              Background="{TemplateBinding Background}"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    BorderThickness="1" CornerRadius="8"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter Margin="10,6,26,6" IsHitTestVisible="False"
                                                  VerticalAlignment="Center" HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <Path Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource Slate400}" StrokeThickness="1.4"
                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,10,0"
                                      IsHitTestVisible="False"/>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                       AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                                    <Border Background="White" BorderBrush="{StaticResource Slate200}"
                                            BorderThickness="1" CornerRadius="8" Margin="0,4,8,8"
                                            MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.12" Color="#0F172A"/>
                                        </Border.Effect>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= DatePicker bo góc, theme slate/blue đồng bộ Input/Select ======= -->
            <Style x:Key="DatePickerTextBoxStyle" TargetType="DatePickerTextBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePickerTextBox">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Ô ngày trong lưới tháng: hôm nay = viền xanh, đang chọn = nền xanh, ngoài tháng = mờ -->
            <Style x:Key="CalDayButtonStyle" TargetType="CalendarDayButton">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarDayButton">
                            <Border x:Name="bd" Margin="2" CornerRadius="6" Background="Transparent"
                                    BorderThickness="1.2" BorderBrush="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate100}"/>
                                </Trigger>
                                <Trigger Property="IsToday" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Blue400}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Slate300}"/>
                                </Trigger>
                                <Trigger Property="IsBlackedOut" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Slate200}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Blue500}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Blue500}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nút chọn Tháng/Năm khi bấm vào tiêu đề header (chế độ Year/Decade) -->
            <Style x:Key="CalMonthYearButtonStyle" TargetType="CalendarButton">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarButton">
                            <Border x:Name="bd" Margin="3" CornerRadius="6" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,8"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate100}"/>
                                </Trigger>
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Slate300}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- "Trang" lịch: card trắng bo góc + đổ bóng nhẹ (cùng ngôn ngữ hình ảnh với popup Select),
                 header có nút lùi/tiến tháng + nút tiêu đề mở chế độ chọn Tháng/Năm. -->
            <Style x:Key="CalItemStyle" TargetType="CalendarItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarItem">
                            <Border Margin="0,4,8,8" Padding="14,12" Background="White"
                                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.14" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: lùi tháng / tiêu đề Tháng-Năm / tiến tháng -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PART_PreviousButton" Grid.Column="0" Width="26" Height="26" Focusable="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="pb" CornerRadius="6" Background="Transparent">
                                                        <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="{StaticResource Slate500}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="pb" Property="Background" Value="{StaticResource Slate100}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="pb" Property="Opacity" Value="0.3"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="PART_HeaderButton" Grid.Column="1" Focusable="False"
                                                HorizontalContentAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="hb" CornerRadius="6" Background="Transparent" Padding="8,3">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          TextElement.FontWeight="SemiBold"
                                                                          TextElement.FontSize="13"
                                                                          TextElement.Foreground="{StaticResource Slate800}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="hb" Property="Background" Value="{StaticResource Slate100}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="PART_NextButton" Grid.Column="2" Width="26" Height="26" Focusable="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="nb" CornerRadius="6" Background="Transparent">
                                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="{StaticResource Slate500}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="nb" Property="Background" Value="{StaticResource Slate100}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="nb" Property="Opacity" Value="0.3"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Hàng tên thứ (T2..CN, tuần bắt đầu Thứ 2) vẽ TĨNH đè lên hàng 0 (trống) của
                                         PART_MonthView. Ẩn khi Calendar chuyển sang lưới chọn Tháng/Năm (Year/Decade). -->
                                    <Grid x:Name="DayNamesRow" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Height="24" IsHitTestVisible="False">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="T2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="1" Text="T3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="2" Text="T4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="3" Text="T5" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="4" Text="T6" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="5" Text="T7" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Slate400}"/>
                                        <TextBlock Grid.Column="6" Text="CN" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Rose400}"/>
                                    </Grid>

                                    <!-- Lưới ngày: hàng 0 để trống (khớp hàng tên thứ tĩnh), hàng 1-6 = CalendarDayButton
                                         do Calendar tự sinh. Chỉ hiện ở chế độ Ngày (Month). -->
                                    <Grid x:Name="PART_MonthView" Grid.Row="1" HorizontalAlignment="Center">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>
                                    </Grid>

                                    <!-- Lưới chọn Tháng (chế độ Year) / Năm (chế độ Decade): Calendar TỰ đổ CalendarButton
                                         (style CalMonthYearButtonStyle) vào đây khi bấm nút tiêu đề header. Chỉ hiện ở Year/Decade. -->
                                    <Grid x:Name="PART_YearView" Grid.Row="1" HorizontalAlignment="Center">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="48"/>
                                            <RowDefinition Height="48"/>
                                            <RowDefinition Height="48"/>
                                        </Grid.RowDefinitions>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DatePickerCalendarStyle" TargetType="Calendar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FirstDayOfWeek" Value="Monday"/>
                <Setter Property="CalendarItemStyle" Value="{StaticResource CalItemStyle}"/>
                <Setter Property="CalendarDayButtonStyle" Value="{StaticResource CalDayButtonStyle}"/>
                <Setter Property="CalendarButtonStyle" Value="{StaticResource CalMonthYearButtonStyle}"/>
            </Style>

            <Style x:Key="DatePickerField" TargetType="DatePicker">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="CalendarStyle" Value="{StaticResource DatePickerCalendarStyle}"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Grid>
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0"
                                                            Style="{StaticResource DatePickerTextBoxStyle}"
                                                            Margin="{TemplateBinding Padding}"/>
                                        <Border Grid.Column="1" Width="1" Margin="0,7" Background="{StaticResource Slate150}"/>
                                        <Button x:Name="PART_Button" Grid.Column="1" Focusable="False"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ib" Background="{TemplateBinding Background}" CornerRadius="0,7,7,0">
                                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="{StaticResource Slate500}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ib" Property="Background" Value="{StaticResource Slate100}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <Popup x:Name="PART_Popup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Blue500}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Thanh tiến trình mini (biểu đồ ngang trên Dashboard) ======= -->
            <Style x:Key="MiniBar" TargetType="ProgressBar">
                <Setter Property="Height" Value="8"/>
                <Setter Property="Background" Value="{StaticResource Slate100}"/>
                <Setter Property="Foreground" Value="{StaticResource Blue500}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Maximum" Value="100"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                        CornerRadius="4" HorizontalAlignment="Left"/>
                                <Border x:Name="PART_Track" Background="Transparent"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ======= Thanh cuộn mảnh, theo theme slate (giống ::-webkit-scrollbar mảnh) ======= -->
            <!-- Thumb: viên nang bo tròn tuyệt đối (bo = nửa bề dày) + đậm dần khi hover/kéo, khớp tông slate toàn app -->
            <Style x:Key="SlimThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="bd" Background="{StaticResource Slate300}" CornerRadius="3"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate400}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Slate500}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Nút bấm vùng track (page up/down) — trong suốt, chỉ để giữ hành vi click-để-cuộn-từng-trang -->
            <Style x:Key="ScrollTrackButton" TargetType="RepeatButton">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="6"/>
                <Setter Property="MinWidth" Value="6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsEnabled}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollTrackButton}" Command="ScrollBar.PageUpCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollTrackButton}" Command="ScrollBar.PageDownCommand"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource SlimThumb}" Margin="1" MinHeight="28"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="6"/>
                        <Setter Property="MinHeight" Value="6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="False" IsEnabled="{TemplateBinding IsEnabled}">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource ScrollTrackButton}" Command="ScrollBar.PageLeftCommand"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Style="{StaticResource ScrollTrackButton}" Command="ScrollBar.PageRightCommand"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource SlimThumb}" Margin="1" MinWidth="28"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ======= DataGrid tương tác (sort / kéo đổi thứ tự / kéo giãn cột / border dọc) ======= -->
            <!-- Header: template tự vẽ border phải (kẻ dọc giữa cột) + giữ gripper resize + mũi tên sort -->
            <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Slate50}"/>
                <Setter Property="Foreground" Value="{StaticResource Slate500}"/>
                <Setter Property="FontSize" Value="10.5"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid>
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource Slate300}"
                                        BorderThickness="0,0,1,1"
                                        SnapsToDevicePixels="True"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                        <Path x:Name="SortArrow" Grid.Column="1" Width="8" Height="6" Margin="8,0,0,0"
                                              VerticalAlignment="Center" Visibility="Collapsed"
                                              Fill="{StaticResource Slate400}" Stretch="Fill"
                                              Data="M 0 4 L 4 0 L 8 4 Z"/>
                                    </Grid>
                                </Border>
                                <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="8" Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                                <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="8" Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="SortDirection" Value="Ascending">
                                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="SortDirection" Value="Descending">
                                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="SortArrow" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter TargetName="SortArrow" Property="RenderTransform">
                                        <Setter.Value><RotateTransform Angle="180"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Cell: bỏ khung focus nét đứt mặc định, thêm padding -->
            <Style x:Key="GridCell" TargetType="DataGridCell">
                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" Padding="14,9" SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Row: hover slate-50, chọn = xanh nhạt.
                 Hover dùng helpers:RowHover (attached, đồng bộ được qua GridPairSync) THAY VÌ IsMouseOver gốc —
                 vì nhiều bảng tách 2 DataGrid riêng (nội dung + cột thao tác ghim phải, cùng 1 ItemsSource),
                 IsMouseOver gốc chỉ sáng ở đúng control đang có chuột, gây lệch hover giữa 2 bảng. -->
            <Style x:Key="GridRow" TargetType="DataGridRow">
                <Setter Property="Background" Value="White"/>
                <Style.Triggers>
                    <Trigger Property="helpers:RowHover.IsHovered" Value="True">
                        <Setter Property="Background" Value="{StaticResource Slate50}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#1A3B82F6"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DataTable" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="AlternationCount" Value="100000"/>
                <!-- Làm tròn độ rộng cột về pixel nguyên để border 1px của header/cell không bị nuốt mất
                     ở một số cột (lỗi render sub-pixel). Áp cho MỌI DataTable trong app. -->
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <!-- Cho phép kéo đổi THỨ TỰ cột (lưu lại qua GridLayoutStore), nhưng KHÔNG cho đổi độ rộng —
                     độ rộng mỗi cột đã tuned cố định, đừng bật CanUserResizeColumns lại. -->
                <Setter Property="CanUserReorderColumns" Value="True"/>
                <Setter Property="CanUserResizeColumns" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="CanUserSortColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <!-- Tự đấu hover + lựa chọn cho MỌI DataGrid (xem GridPairSync) — bảng nào tách thêm cột thao
                     tác riêng thì View gọi GridPairSync.Link(...) để nối 2 bảng (KHÔNG dùng
                     IsSynchronizedWithCurrentItem — từng gây bug tự chọn lại dòng đầu mỗi khi View gọi
                     _view.Refresh(), xem chú thích trong GridPairSync.cs), còn lại tự hoạt động không cần gì thêm. -->
                <Setter Property="helpers:GridPairSync.AutoHover" Value="True"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Slate200}"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="MinRowHeight" Value="40"/>
                <Setter Property="ColumnHeaderHeight" Value="38"/>
                <!-- Chiều cao dòng 40px thống nhất TOÀN APP; viewport giới hạn ~16 dòng (header 38 + 16×40 + đệm thanh
                     cuộn ngang ≈ 700) — bảng nào nhiều dòng hơn tự cuộn DỌC bên trong (không đẩy cả trang cao vô hạn).
                     Bảng set RowHeight riêng cũng dùng 40 + MinRowHeight=40 (sàn của style là 40 nên phải override cả
                     MinRowHeight nếu muốn thấp hơn) + MaxHeight=700 cho khớp 16 dòng — xem LotsView/ReceiptReportView. -->
                <Setter Property="MaxHeight" Value="700"/>
                <!-- Ảo hóa dòng BẬT + Recycling (hiệu năng cao nhất: chỉ dựng ~số dòng đang thấy + tái dùng container,
                     dữ liệu lớn vẫn mở nhanh). STT KHÔNG dùng AlternationIndex nữa (bị lệch/nhảy ~99999 khi cuộn với
                     ảo hóa — cả Recycling lẫn Standard) mà dùng RowNumbering (GetIndex qua LoadingRow, đúng tuyệt đối).
                     ĐỪNG tắt ảo hóa để "sửa STT" (tắt = dựng hết N dòng → đơ khi dữ liệu lớn). Scroll sync với ActionGrid
                     đôi khi ném "Index outside bounds" lúc ảo hóa đang dựng container → đã nuốt an toàn ở
                     GridPairSync.WireScroll + handler lỗi toàn cục. -->
                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                <Setter Property="EnableRowVirtualization" Value="True"/>
                <Setter Property="helpers:RowNumbering.Enabled" Value="True"/>
                <!-- Visible (không phải Auto) — thanh cuộn ngang luôn hiện trên viewport để người dùng biết
                     bảng còn cột tràn ngoài tầm nhìn, kể cả khi chưa cuộn/hover tới. -->
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Visible"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
                <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridHeader}"/>
                <Setter Property="CellStyle" Value="{StaticResource GridCell}"/>
                <Setter Property="RowStyle" Value="{StaticResource GridRow}"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
