<UserControl x:Class="TimberFlowDesktop.Views.DotNetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <Grid Background="{StaticResource Slate50}">
        <Border Style="{StaticResource Card}" Margin="24" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Slate900}" CornerRadius="12,12,0,0" Padding="20,14">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource Blue400}" VerticalAlignment="Center"/>
                            <TextBlock Text="Mã Nguồn Nghiệp Vụ — Clean Architecture (.NET 8 / WPF)"
                                       Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="10,0,0,0"/>
                        </StackPanel>
                        <Border Background="#331E293B" CornerRadius="4" Padding="8,3"
                                HorizontalAlignment="Right" BorderBrush="{StaticResource Slate700}" BorderThickness="1">
                            <TextBlock Text="Domain/WoodVolumeCalculator.cs" FontFamily="{StaticResource FontMono}"
                                       FontSize="10" Foreground="{StaticResource Slate400}"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#0B1120" CornerRadius="0,0,12,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="20">
                        <TextBlock x:Name="CodeBlock" FontFamily="{StaticResource FontMono}" FontSize="12"
                                   Foreground="#C9D6E8" LineHeight="19"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
