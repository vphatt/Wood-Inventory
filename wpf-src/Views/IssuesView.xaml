<UserControl x:Class="TimberFlowDesktop.Views.IssuesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↗" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Phiếu Xuất Kho Gỗ Cho Đơn Hàng" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Xuất nguyên liệu gỗ phục vụ sản xuất. Truy xuất giá vốn thực tế của kiện gỗ đã chọn."
                               FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnToggleAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock Text="Tạo phiếu xuất mới"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Form lập phiếu xuất ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- Banner truy xuất -->
                    <Border Background="{StaticResource Blue50}" BorderBrush="{StaticResource Blue100}"
                            BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource Blue800}" VerticalAlignment="Top" Margin="0,2,10,0"/>
                            <StackPanel MaxWidth="900">
                                <TextBlock Text="Tính năng truy xuất nguồn gốc và hạch toán giá vốn:" FontWeight="Bold"
                                           Foreground="{StaticResource Blue800}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Blue800}" Margin="0,3,0,0"
                                           LineHeight="18"
                                           Text="Hệ thống ERP tuân thủ nguyên tắc hạch toán đích danh (Specific Lot Traceability). Khi xuất gỗ, bạn chỉ định rõ xuất từ kiện gỗ (Lot) nào. Hệ thống tự động quy đổi thể tích m³ đã xuất, khấu trừ tồn kho tương ứng, và gán chính xác giá vốn gốc của kiện đó vào chi phí nguyên liệu sản xuất cho đơn hàng."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Đơn hàng + ngày -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LỆNH / ĐƠN HÀNG SẢN XUẤT" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FOrder" Style="{StaticResource Select}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NGÀY XUẤT KHO" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="FDate" Style="{StaticResource DatePickerField}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="CHI TIẾT CÁC KIỆN GỖ XUẤT" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource Slate700}" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource BtnLink}" HorizontalAlignment="Right" Click="BtnAddRow_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,2,4,0"/>
                                <TextBlock Text="Thêm kiện gỗ xuất"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Bảng các dòng xuất -->
                    <Border BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel MinWidth="1075">
                                <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                                        BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*" MinWidth="200"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="115"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="STT" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="KIỆN GỖ NGUỒN (LOT ID)" Style="{StaticResource THead}" Margin="12,9"/>
                                        <TextBlock Grid.Column="2" Text="LOẠI GỖ / THÔNG SỐ KIỆN" Style="{StaticResource THead}" Margin="12,9"/>
                                        <TextBlock Grid.Column="3" Text="TỒN KHẢ DỤNG" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="SỐ LƯỢNG XUẤT" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="THỂ TÍCH XUẤT (M³)" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="6" Text="GIÁ VỐN VND/M³" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="7" Text="CHI PHÍ XUẤT" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="8" Text="XÓA" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ItemsControl x:Name="IssueRowsPanel"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Khối lỗi -->
                    <Border x:Name="ErrorPanel" Background="{StaticResource Rose50}" BorderBrush="{StaticResource Rose200}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0" Visibility="Collapsed">
                        <StackPanel x:Name="ErrorList"/>
                    </Border>

                    <!-- Tổng + nút -->
                    <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Tổng m³ xuất:" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCbm" Text="0.0000 m³" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Blue600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tổng giá trị vốn xuất:" Foreground="{StaticResource Slate500}"
                                           Margin="24,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalValue" Text="0 ₫" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Rose600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource BtnGhost}" Content="Hủy bỏ" Click="BtnCancelAdd_Click"/>
                                <Button Style="{StaticResource BtnPrimary}" Content="Xác nhận xuất kho sản xuất"
                                        Margin="8,0,0,0" Click="BtnSaveIssue_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc lịch sử ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="Tìm số phiếu, kiện gỗ..." FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <ComboBox x:Name="FilterOrder" Style="{StaticResource Select}" MinWidth="260" MaxWidth="360"
                          Margin="12,0,0,0" SelectionChanged="Filter_Changed"/>
            </StackPanel>

            <!-- ===== Lịch sử phiếu xuất (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Grid>
                    <DataGrid x:Name="HistoryGrid" Style="{StaticResource DataTable}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SỐ PHIẾU XUẤT" Binding="{Binding Id}" Width="130" MinWidth="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate900}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="LỆNH / ĐƠN HÀNG SẢN XUẤT" SortMemberPath="OrderId" Width="280" MinWidth="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding OrderId}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Slate800}"/>
                                            <TextBlock Text="{Binding CustomerName}" FontSize="10"
                                                       Foreground="{StaticResource Slate400}" Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="NGÀY XUẤT" Binding="{Binding DateText}" Width="110" MinWidth="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="KIỆN GỖ NGUỒN" Width="200" MinWidth="150" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding LotIds}" VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource Blue50}" CornerRadius="4"
                                                            Padding="6,2" Margin="0,2,6,2">
                                                        <TextBlock Text="{Binding}" FontSize="10" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource FontMono}"
                                                                   Foreground="{StaticResource Blue700}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="TỔNG THANH XUẤT" Binding="{Binding QtyText}" Width="120" MinWidth="110" SortMemberPath="Qty">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="TỔNG THỂ TÍCH M³" Binding="{Binding VolText}" Width="140" MinWidth="130" SortMemberPath="Vol">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="HẠCH TOÁN GIÁ VỐN" Binding="{Binding ValText}" Width="160" MinWidth="140" SortMemberPath="Val">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Rose600}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="EmptyRow" Text="Không có phiếu xuất nào khớp bộ lọc."
                               Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
