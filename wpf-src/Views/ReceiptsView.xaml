<UserControl x:Class="WoodInventory.Views.ReceiptsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <Grid Background="{StaticResource Slate50}">
      <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="{helpers:Loc Receipts.Title}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource BtnGhost}" Click="BtnOpenReport_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                            <TextBlock Text="{helpers:Loc Receipts.OpenReportButton}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Click="BtnToggleAdd_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                            <TextBlock Text="{helpers:Loc Receipts.AddButton}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Form lập phiếu nhập ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- Tiêu đề form (đổi theo chế độ add/view/edit) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="{helpers:Loc Receipts.Form.AddTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Thông tin chứng từ — dòng 1: NCC / Ngày / Hóa đơn -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{helpers:Loc Receipts.Field.Supplier}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FSupplier" Style="{StaticResource Select}" SelectionChanged="FSupplier_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{helpers:Loc Receipts.Field.Date}" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="FDate" Style="{StaticResource DatePickerField}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{helpers:Loc Receipts.Field.Invoice}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FInvoice" Style="{StaticResource Input}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Thông tin chứng từ — dòng 2: Packing List / Bảng kê lâm sản / Đơn vị tiền tệ & tỷ giá / Thuế -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{helpers:Loc Receipts.Field.PackingList}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FPackingList" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{helpers:Loc Receipts.Field.ForestList}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FForestList" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{helpers:Loc Receipts.Field.CurrencyRate}" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="FCurrency" Grid.Column="0" Style="{StaticResource Select}" SelectionChanged="FCurrency_Changed">
                                    <ComboBoxItem Content="USD" Tag="USD"/>
                                    <ComboBoxItem Content="VND" Tag="VND"/>
                                </ComboBox>
                                <TextBox x:Name="FExchangeRate" Grid.Column="2" Style="{StaticResource Input}" Text="25400"
                                         FontFamily="{StaticResource FontMono}" TextChanged="FRate_Changed"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="{helpers:Loc Receipts.Field.Tax}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FTaxPercent" Style="{StaticResource Select}" SelectionChanged="FRate_Changed"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{helpers:Loc Receipts.LotSection.Title}" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource Slate700}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnAddLotRow" Style="{StaticResource BtnLink}" HorizontalAlignment="Right" Click="BtnAddLotRow_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,2,4,0"/>
                                <TextBlock Text="{helpers:Loc Receipts.AddLotRow}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Bảng khai báo kiện -->
                    <Border BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Header: cuộn ngang đồng bộ với body, ẩn thanh cuộn riêng -->
                            <ScrollViewer x:Name="LotHeaderScroll" Grid.Row="0"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                                        BorderThickness="0,0,0,1" CornerRadius="8,8,0,0"
                                        HorizontalAlignment="Left" MinWidth="2065">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*" MinWidth="130"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{helpers:Loc Common.Column.Stt}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{helpers:Loc Receipts.Column.LotId}" Style="{StaticResource THead}" Margin="12,9"/>
                                        <TextBlock Grid.Column="2" Text="{helpers:Loc Receipts.Column.DeliveryNote}" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="3" Text="{helpers:Loc Receipts.Column.WoodType}" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="4" Text="{helpers:Loc Receipts.Column.SubType}" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="5" Text="{helpers:Loc Receipts.Column.Origin}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="{helpers:Loc Receipts.Column.Grade}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="7" Text="{helpers:Loc Receipts.Column.Thickness}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="8" Text="{helpers:Loc Receipts.Column.Width}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="9" Text="{helpers:Loc Receipts.Column.Length}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="10" Text="{helpers:Loc Receipts.Column.Footage}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="11" Text="{helpers:Loc Receipts.Column.Quantity}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="12" Text="{helpers:Loc Receipts.Column.Volume}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="13" Text="{helpers:Loc Receipts.Column.Decimals}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center" ToolTip="{helpers:Loc Receipts.Column.DecimalsTooltip}"/>
                                        <TextBlock Grid.Column="14" Text="{helpers:Loc Receipts.Column.Adjustment}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right" ToolTip="{helpers:Loc Receipts.Column.AdjustmentTooltip}"/>
                                        <TextBlock Grid.Column="15" Text="{helpers:Loc Receipts.Column.Price}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="16" Text="{helpers:Loc Receipts.Column.TotalOriginal}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right" ToolTip="{helpers:Loc Receipts.Column.TotalOriginalTooltip}"/>
                                        <TextBlock Grid.Column="17" Text="{helpers:Loc Receipts.Column.TotalVnd}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="18" Text="{helpers:Loc Receipts.Column.TaxVnd}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="19" Text="{helpers:Loc Receipts.Column.GrandTotal}" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="20" Text="{helpers:Loc Receipts.Column.Delete}" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ScrollViewer>
                            <!-- Body: thanh cuộn DỌC ghim mép phải viewport (luôn hiện) + thanh cuộn ngang dưới, đồng bộ ngang với header -->
                            <ScrollViewer x:Name="LotBodyScroll" Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          ScrollChanged="LotBodyScroll_ScrollChanged">
                                <StackPanel HorizontalAlignment="Left" MinWidth="2065">
                                    <ItemsControl x:Name="LotRowsPanel"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Tổng + nút -->
                    <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{helpers:Loc Receipts.Totals.Volume}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCbm" Text="0.0000 m³" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Blue600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{helpers:Loc Receipts.Totals.Value}" Foreground="{StaticResource Slate500}"
                                           Margin="20,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalValue" Text="0 ₫" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Emerald600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="{helpers:Loc Common.Cancel}" Click="BtnCancelAdd_Click"/>
                                <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="{helpers:Loc Receipts.SaveButton}"
                                        Margin="8,0,0,0" Click="BtnSaveReceipt_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc lịch sử ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,30,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <Button Style="{StaticResource SearchClearBtn}" helpers:ClearBox.Target="{Binding ElementName=SearchBox}"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="{helpers:Loc Receipts.SearchHint}" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                        Click="BtnToggleColumnFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                        Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
            <Border x:Name="ColumnFilterPanel" Background="{StaticResource Slate50}"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,16" Visibility="Collapsed">
                <UniformGrid Columns="5" Rows="2">
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Id}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FIdFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Field.Supplier}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FilterSupplier" Style="{StaticResource Select}" SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Date}" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="FDateFilter" Style="{StaticResource DatePickerField}" SelectedDateChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Invoice}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FInvoiceFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.LotCount}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FLotCountFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Vol}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FVolFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.TotalVnd}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FVndFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Tax}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FTaxFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Val}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FValFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Lịch sử phiếu nhập (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="HistoryGrid" Grid.Column="0" Style="{StaticResource DataTable}" CanUserSortColumns="True"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(helpers:RowNumbering.Number)}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.Id}" Binding="{Binding Id}" Width="130" MinWidth="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate900}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Field.Supplier}" Binding="{Binding SupplierName}" Width="200" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn x:Name="ColRecDate" Header="{helpers:Loc Receipts.Filter.Date}" Binding="{Binding DateText}" Width="110" MinWidth="100" SortMemberPath="Date">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="{helpers:Loc Receipts.Filter.Invoice}" Width="160" MinWidth="140" SortMemberPath="Invoice">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="{StaticResource Slate100}" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding InvoiceText}" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource Slate600}"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.LotCount}" Binding="{Binding LotCountText}" Width="90" MinWidth="80" SortMemberPath="LotCount">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.Vol}" Binding="{Binding VolText}" Width="140" MinWidth="120" SortMemberPath="Vol">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Column.TotalVnd}" Binding="{Binding VndText}" Width="150" MinWidth="130" SortMemberPath="VndTotal">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.Tax}" Binding="{Binding TaxText}" Width="150" MinWidth="130" SortMemberPath="TaxTotal">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.Val}" Binding="{Binding ValText}" Width="150" MinWidth="130" SortMemberPath="Val">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Emerald600}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                    <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}"
                              BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                              ScrollViewer.HorizontalScrollBarVisibility="Visible"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{helpers:Loc Common.Column.Actions}" Width="100" MinWidth="100"
                                                    CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnIcon}" ToolTip="{helpers:Loc Common.Tooltip.View}" Click="ViewRow_Click">
                                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                            <Button Style="{StaticResource BtnIconDanger}" ToolTip="{helpers:Loc Receipts.Tooltip.Delete}"
                                                    Margin="8,0,0,0" Click="DeleteRow_Click">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="{helpers:Loc Receipts.Empty}"
                               Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                </Grid>
            </Border>

        </StackPanel>
      </ScrollViewer>
      <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
