<UserControl x:Class="WoodInventory.Views.ReceiptsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <Grid Background="{StaticResource Slate50}">
      <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Phiếu Nhập Kho Gỗ Nguyên Liệu" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource BtnGhost}" Click="BtnOpenReport_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                            <TextBlock Text="Bảng tổng chi tiết nhập kho"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Click="BtnToggleAdd_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                            <TextBlock Text="Lập phiếu nhập mới"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== Form lập phiếu nhập ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <!-- Tiêu đề form (đổi theo chế độ add/view/edit) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="Lập Phiếu Nhập Kho Mới" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Thông tin chứng từ -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="14"/>
                            <RowDefinition/>
                            <RowDefinition Height="14"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="NHÀ CUNG CẤP" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FSupplier" Style="{StaticResource Select}" SelectionChanged="FSupplier_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="NGÀY NHẬP KHO" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="FDate" Style="{StaticResource DatePickerField}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="4">
                            <TextBlock Text="SỐ HÓA ĐƠN (INVOICE)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FInvoice" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="PACKING LIST" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FPackingList" Style="{StaticResource Input}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="TỶ GIÁ VND/USD" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FExchangeRate" Style="{StaticResource Input}" Text="25400"
                                     FontFamily="{StaticResource FontMono}" TextChanged="FRate_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="4">
                            <TextBlock Text="THUẾ VAT (%)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FTaxPercent" Style="{StaticResource Select}" SelectionChanged="FRate_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="BẢNG KÊ LÂM SẢN" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FForestList" Style="{StaticResource Input}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="KHAI BÁO DANH MỤC KIỆN GỖ KÈM THEO" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource Slate700}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnAddLotRow" Style="{StaticResource BtnLink}" HorizontalAlignment="Right" Click="BtnAddLotRow_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,2,4,0"/>
                                <TextBlock Text="Thêm kiện hàng"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Bảng khai báo kiện -->
                    <Border BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel MinWidth="1970">
                                <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                                        BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="45"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*" MinWidth="130"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="STT" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="MÃ KIỆN" Style="{StaticResource THead}" Margin="12,9"/>
                                        <TextBlock Grid.Column="2" Text="PHIẾU GIAO HÀNG" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="3" Text="LOẠI GỖ" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="4" Text="PHÂN LOẠI" Style="{StaticResource THead}" Margin="6,9"/>
                                        <TextBlock Grid.Column="5" Text="XUẤT XỨ" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="DÀY" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="7" Text="RỘNG" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="8" Text="DÀI" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="9" Text="FOOTAGE" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="10" Text="SỐ LƯỢNG" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="11" Text="THỂ TÍCH M³" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="12" Text="SỐ TP" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center" ToolTip="Số chữ số thập phân làm tròn m³ của riêng dòng này"/>
                                        <TextBlock Grid.Column="13" Text="ĐIỀU CHỈNH" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right" ToolTip="Cộng/trừ thêm vào m³ sau khi làm tròn, vd +0,0001 hoặc -0,0002"/>
                                        <TextBlock Grid.Column="14" Text="ĐƠN GIÁ USD" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="15" Text="TỔNG TIỀN USD" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="16" Text="TỔNG TIỀN VND" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="17" Text="TIỀN THUẾ VND" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="18" Text="TỔNG CỘNG VND" Style="{StaticResource THead}" Margin="6,9" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="19" Text="XÓA" Style="{StaticResource THead}" Margin="0,9" HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ItemsControl x:Name="LotRowsPanel"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Tổng + nút -->
                    <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Tổng m³ của phiếu:" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCbm" Text="0.0000 m³" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Blue600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tổng trị giá nhập kho:" Foreground="{StaticResource Slate500}"
                                           Margin="20,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalValue" Text="0 ₫" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Emerald600}"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="Hủy bỏ" Click="BtnCancelAdd_Click"/>
                                <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="Lưu phiếu nhập kho"
                                        Margin="8,0,0,0" Click="BtnSaveReceipt_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc lịch sử ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="Tìm số phiếu, invoice..." FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <ComboBox x:Name="FilterSupplier" Style="{StaticResource Select}" MinWidth="220" MaxWidth="300"
                          Margin="12,0,0,0" SelectionChanged="Filter_Changed"/>
            </StackPanel>

            <!-- ===== Lịch sử phiếu nhập (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="HistoryGrid" Grid.Column="0" Style="{StaticResource DataTable}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SỐ PHIẾU NHẬP" Binding="{Binding Id}" Width="130" MinWidth="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate900}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="NHÀ CUNG CẤP" Binding="{Binding SupplierName}" Width="*" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="NGÀY NHẬP" Binding="{Binding DateText}" Width="110" MinWidth="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="SỐ HÓA ĐƠN" Width="160" MinWidth="140" SortMemberPath="Invoice">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="{StaticResource Slate100}" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{Binding InvoiceText}" FontSize="10" FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource Slate600}"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="SỐ KIỆN" Binding="{Binding LotCountText}" Width="90" MinWidth="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="TỔNG THỂ TÍCH M³" Binding="{Binding VolText}" Width="140" MinWidth="120" SortMemberPath="Vol">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="TỔNG TIỀN VND" Binding="{Binding VndText}" Width="150" MinWidth="130" SortMemberPath="VndTotal">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="TỔNG TIỀN THUẾ" Binding="{Binding TaxText}" Width="150" MinWidth="130" SortMemberPath="TaxTotal">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="TỔNG GIÁ TRỊ" Binding="{Binding ValText}" Width="150" MinWidth="130" SortMemberPath="Val">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Emerald600}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                    <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}"
                              BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="THAO TÁC" Width="130" MinWidth="130"
                                                    CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource BtnIcon}" ToolTip="Xem chi tiết" Click="ViewRow_Click">
                                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                            <Button Style="{StaticResource BtnIcon}" ToolTip="Chỉnh sửa"
                                                    Margin="8,0,0,0" Click="EditRow_Click">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                            <Button Style="{StaticResource BtnIconDanger}" ToolTip="Xóa phiếu nhập"
                                                    Margin="8,0,0,0" Click="DeleteRow_Click">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="Không có phiếu nhập nào khớp bộ lọc."
                               Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                </Grid>
            </Border>

        </StackPanel>
      </ScrollViewer>
      <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
