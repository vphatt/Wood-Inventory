<UserControl x:Class="WoodInventory.Views.LotsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <Grid Background="{StaticResource Slate50}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,12,24,0">
            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
            <TextBlock Text="{helpers:Loc Nav.Lots}" FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Thanh công cụ (Odoo style) -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Slate200}"
                BorderThickness="0,0,0,1" Padding="24,14" Margin="0,10,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Grid Width="256">
                        <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,30,6"
                                 Background="{StaticResource Slate50}" TextChanged="Filters_Changed"/>
                        <Button Style="{StaticResource SearchClearBtn}" helpers:ClearBox.Target="{Binding ElementName=SearchBox}"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBlock x:Name="SearchHint" Text="{helpers:Loc Lots.SearchHint}" FontSize="12"
                                   Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>
                    <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                            Click="BtnToggleColumnFilters_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                            <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                            Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
        <Border x:Name="ColumnFilterPanel" Grid.Row="2" Background="{StaticResource Slate50}"
                BorderBrush="{StaticResource Slate200}" BorderThickness="0,0,0,1" Padding="24,16"
                Visibility="Collapsed">
            <UniformGrid Columns="5" Rows="3">
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Field.Supplier}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="FilterSupplier" Style="{StaticResource Select}" SelectionChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Invoice}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FInvoiceFilter" Style="{StaticResource Input}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Field.Date}" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="FImportDateFilter" Style="{StaticResource DatePickerField}" SelectedDateChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.DeliveryNote}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FDeliveryNoteFilter" Style="{StaticResource Input}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.LotId}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FIdFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc ReceiptReport.Filter.WoodType}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="FilterWoodType" Style="{StaticResource Select}" SelectionChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc ReceiptReport.Filter.SubType}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="FilterSubType" Style="{StaticResource Select}" SelectionChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.Grade}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FGradeFilter" Style="{StaticResource Input}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.Thickness}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FDayFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.Width}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FWidthFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.Length}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FLengthFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Receipts.Column.Footage}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FFootageFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc Lots.Filter.Qty}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FQtyFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,12">
                    <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Vol}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FVolFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filters_Changed"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Vùng nội dung: bảng + panel chi tiết -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">

                    <!-- ===== Bảng kiện gỗ (DataGrid tương tác) ===== -->
                    <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                        <DockPanel>
                            <!-- Footer tổng -->
                            <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                                    BorderThickness="0,1,0,0" Padding="24,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{helpers:Loc Lots.Totals.Qty}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TotalQty" Text="0 thanh" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{helpers:Loc Lots.Totals.Vol}" Foreground="{StaticResource Slate500}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TotalVol" Text="0.0000 m³" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource Blue600}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{helpers:Loc Lots.Totals.Val}" Foreground="{StaticResource Slate500}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TotalVal" Text="0 ₫" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{StaticResource Emerald600}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DataGrid x:Name="LotGrid" Grid.Column="0" Style="{StaticResource DataTable}" RowHeight="40" MinRowHeight="40" MaxHeight="700" CanUserSortColumns="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(helpers:RowNumbering.Number)}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Field.Supplier}" Binding="{Binding SupplierName}" Width="240" MinWidth="240">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Invoice}" Binding="{Binding InvoiceText}" Width="130" MinWidth="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn x:Name="ColLotDate" Header="{helpers:Loc Receipts.Field.Date}" Binding="{Binding ImportDateText}" Width="136" MinWidth="126" SortMemberPath="ImportDate">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.DeliveryNote}" Binding="{Binding DeliveryNoteText}" Width="140" MinWidth="130">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.LotId}" Binding="{Binding Id}" Width="110" MinWidth="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate900}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.WoodType}" Binding="{Binding WoodTypeText}" Width="130" MinWidth="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.SubType}" Binding="{Binding SubTypeText}" Width="120" MinWidth="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <!-- Chất lượng (Grade) — bên trái cột Dày -->
                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Grade}" Binding="{Binding GradeText}" Width="100" MinWidth="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Thickness}" Binding="{Binding DayText}" Width="76" MinWidth="66" SortMemberPath="ThicknessMm">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Width}" Binding="{Binding WidthText}" Width="76" MinWidth="66" SortMemberPath="WidthMm">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Length}" Binding="{Binding LengthText}" Width="112" MinWidth="96" SortMemberPath="LengthMm">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Footage}" Binding="{Binding FootageText}" Width="92" MinWidth="80" SortMemberPath="Footage">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="{helpers:Loc Lots.Filter.Qty}" Width="140" MinWidth="120" SortMemberPath="Quantity">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="pill" CornerRadius="999" Padding="8,2" Background="{StaticResource Slate100}"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock x:Name="pillText" Text="{Binding QtyText}" FontSize="10"
                                                                   FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Slate700}"/>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsLow}" Value="True">
                                                            <Setter TargetName="pill" Property="Background" Value="{StaticResource Rose50}"/>
                                                            <Setter TargetName="pillText" Property="Foreground" Value="{StaticResource Rose600}"/>
                                                            <Setter TargetName="pillText" Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Vol}" Binding="{Binding VolText}" Width="120" MinWidth="110" SortMemberPath="RemainingCbm">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                                <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}" RowHeight="40" MinRowHeight="40" MaxHeight="700"
                                          BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="{helpers:Loc Common.Column.Actions}" Width="100" MinWidth="100" CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource BtnIcon}" ToolTip="{helpers:Loc Common.Tooltip.View}" Click="ViewRow_Click">
                                                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                        </Button>
                                                        <Button Style="{StaticResource BtnIconDanger}" ToolTip="{helpers:Loc Lots.Tooltip.Delete}" Margin="6,0,0,0" Click="DeleteRow_Click">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="{helpers:Loc Lots.Empty}"
                                           Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                            </Grid>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Panel chi tiết / truy xuất ===== -->
            <Border x:Name="DetailPanel" Grid.Column="1" Width="320" Background="White"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <Grid Margin="0,0,0,12">
                            <TextBlock x:Name="DetailTitle" Text="Truy xuất kiện:" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource Slate800}"/>
                            <Button Style="{StaticResource BtnLink}" Content="{helpers:Loc Common.Close}" HorizontalAlignment="Right"
                                    Foreground="{StaticResource Slate400}" Click="BtnCloseDetail_Click"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                        <!-- Thông tin kỹ thuật -->
                        <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate150}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{helpers:Loc Lots.Detail.GeneralInfo}" FontWeight="SemiBold" Foreground="{StaticResource Slate700}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.WoodType}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DWoodType" FontWeight="Medium" Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Origin}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DOrigin" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Spec}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DSpec" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid x:Name="DFootageRow" Visibility="Collapsed" Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Footage}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DFootage" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Blue600}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid x:Name="DLengthNoteRow" Visibility="Collapsed">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Length}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DLengthNote" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Công thức -->
                        <Border Background="#59EFF6FF" BorderBrush="{StaticResource Blue100}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{helpers:Loc Lots.Detail.FormulaTitle}" FontWeight="SemiBold"
                                               Foreground="{StaticResource Slate700}" Margin="6,0,0,0"/>
                                </StackPanel>
                                <Border Background="White" BorderBrush="{StaticResource Slate100}" BorderThickness="1"
                                        CornerRadius="6" Padding="8">
                                    <TextBlock x:Name="DFormula" FontSize="11" FontFamily="{StaticResource FontMono}"
                                               FontStyle="Italic" Foreground="{StaticResource Slate500}"
                                               TextWrapping="Wrap" LineHeight="17"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Tài chính & thuế -->
                        <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate150}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{helpers:Loc Lots.Detail.FinanceTitle}" FontWeight="SemiBold" Foreground="{StaticResource Slate700}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Price}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DPriceUsd" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.ExchangeRate}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DExchangeRate" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Tax}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DTax" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource Slate200}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Subtotal}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DSubtotal" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Vat}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DVat" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Total}" FontWeight="SemiBold" Foreground="{StaticResource Slate700}"/>
                                    <TextBlock x:Name="DTotal" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Blue600}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource Slate200}" Margin="0,0,0,8"/>
                                <Grid>
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Used}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DUsed" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Rose500}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Chứng từ -->
                        <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate150}"
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{helpers:Loc Lots.Detail.DocsTitle}" FontWeight="SemiBold" Foreground="{StaticResource Slate700}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Supplier}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DSupplier" FontWeight="Medium" Foreground="{StaticResource Slate800}"
                                               HorizontalAlignment="Right" TextAlignment="Right"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.Invoice}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DInvoice" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.ForestList}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DForestList" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"
                                               TextAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{helpers:Loc Lots.Detail.PackingList}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DPackingList" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="{helpers:Loc Lots.Detail.DeliveryNote}" Foreground="{StaticResource Slate500}"/>
                                    <TextBlock x:Name="DDeliveryNote" FontWeight="Medium" FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource Slate800}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Lịch sử xuất kho -->
                        <TextBlock Text="{helpers:Loc Lots.Detail.HistoryTitle}" FontSize="10.5" FontWeight="Bold"
                                   Foreground="{StaticResource Slate500}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DHistoryEmpty" Text="{helpers:Loc Lots.Detail.HistoryEmpty}"
                                   FontSize="11" FontStyle="Italic" Foreground="{StaticResource Slate400}"
                                   TextWrapping="Wrap"/>
                        <ItemsControl x:Name="DHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Slate200}" BorderThickness="1"
                                            CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="{Binding IssueText}" FontWeight="Bold" Foreground="{StaticResource Slate700}"/>
                                                <TextBlock Text="{Binding QtyText}" FontWeight="Bold" Foreground="{StaticResource Rose500}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="{Binding OrderText}" FontSize="11" Foreground="{StaticResource Slate500}"/>
                                                <TextBlock Text="{Binding CbmText}" FontSize="11" Foreground="{StaticResource Slate500}"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="{Binding DateText}" FontSize="10" Foreground="{StaticResource Slate400}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
