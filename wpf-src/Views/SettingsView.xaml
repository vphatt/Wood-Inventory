<UserControl x:Class="WoodInventory.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24" MaxWidth="1100" HorizontalAlignment="Left">

            <!-- Tiêu đề + nút Hủy/Lưu -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Cài Đặt" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="BtnDiscard" Style="{StaticResource BtnGhost}" Content="Hủy thay đổi" Click="BtnDiscard_Click"/>
                    <Button x:Name="BtnSave" Style="{StaticResource BtnPrimary}" Content="Lưu cài đặt"
                            Margin="8,0,0,0" Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===== Thông tin công ty ===== -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Thông Tin Công Ty" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Slate800}" Margin="0,0,0,6"/>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="TÊN CÔNG TY *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FCompanyName" Style="{StaticResource Input}"
                                     Tag="{Binding ElementName=WCompanyName}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WCompanyName" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="MÃ SỐ THUẾ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FCompanyTaxCode" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,14">
                            <TextBlock Text="SỐ ĐIỆN THOẠI" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FCompanyPhone" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5">
                            <TextBlock Text="ĐỊA CHỈ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FCompanyAddress" Style="{StaticResource Input}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Thiết lập mặc định ===== -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Thiết Lập Mặc Định" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Slate800}" Margin="0,0,0,6"/>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TỶ GIÁ VND/USD MẶC ĐỊNH *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FExchangeRate" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                     Tag="{Binding ElementName=WExchangeRate}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WExchangeRate" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="% THUẾ VAT MẶC ĐỊNH" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FTaxPercent" Style="{StaticResource Select}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="SỐ LÀM TRÒN MẶC ĐỊNH *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FVolumeDecimals" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                     Tag="{Binding ElementName=WVolumeDecimals}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WVolumeDecimals" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="NGƯỠNG CẢNH BÁO TỒN KHO THẤP *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FLowStockThreshold" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                     Tag="{Binding ElementName=WLowStockThreshold}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WLowStockThreshold" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Ngôn ngữ ===== -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{helpers:Loc Settings.Language.Title}" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Slate800}" Margin="0,0,0,6"/>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <StackPanel MaxWidth="360">
                        <TextBlock Text="{helpers:Loc Settings.Language.Label}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FLanguage" Style="{StaticResource Select}" SelectionChanged="FLanguage_Changed"/>
                        <TextBlock Text="{helpers:Loc Settings.Language.Hint}"
                                   FontSize="11" Foreground="{StaticResource Slate500}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Dữ liệu ===== -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dữ Liệu" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Slate800}" Margin="0,0,0,6"/>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>
                    <TextBlock Text="Toàn bộ dữ liệu lưu cục bộ trong 1 file SQLite trên máy này, không đồng bộ lên mạng."
                               FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,0,0,14" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnBackup" Style="{StaticResource BtnPrimary}" Click="BtnBackup_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,6,0"/>
                                <TextBlock Text="Sao lưu ngay"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnRestore" Style="{StaticResource BtnGhost}" Margin="8,0,0,0" Click="BtnRestore_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,6,0"/>
                                <TextBlock Text="Phục hồi từ file sao lưu"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnOpenDataFolder" Style="{StaticResource BtnGhost}" Margin="8,0,0,0" Click="BtnOpenDataFolder_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,6,0"/>
                                <TextBlock Text="Mở thư mục dữ liệu"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
