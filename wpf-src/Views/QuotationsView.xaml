<UserControl x:Class="WoodInventory.Views.QuotationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <!-- ================= DANH SÁCH NHÀ CUNG CẤP ================= -->
        <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
            <StackPanel Margin="24">

                <!-- Tiêu đề -->
                <StackPanel Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Quản Lý Báo Giá Gỗ Nhà Cung Cấp" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tìm kiếm -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Grid Width="340">
                        <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                                 Background="White" TextChanged="Filter_Changed"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBlock x:Name="SearchHint" Text="Tìm nhà cung cấp..." FontSize="12"
                                   Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>

                <!-- Bảng NCC + báo giá -->
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <DockPanel>
                        <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                                BorderThickness="0,1,0,0" Padding="24,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tổng số nhà cung cấp:" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid x:Name="SupplierGrid" Grid.Column="0" Style="{StaticResource DataTable}" RowHeight="56">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                        Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="NHÀ CUNG CẤP" SortMemberPath="Name" Width="*" MinWidth="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource Slate800}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding CodeLabel}" FontSize="10"
                                                               Foreground="{StaticResource Slate400}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="SỐ MỤC GIÁ" Binding="{Binding ItemCountText}" Width="130" MinWidth="110" SortMemberPath="ItemCount">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="NGÀY ÁP DỤNG" Binding="{Binding DateText}" Width="150" MinWidth="130" SortMemberPath="Date">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                                <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                            <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}" RowHeight="56"
                                      BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="THAO TÁC" Width="150" MinWidth="150"
                                                            CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource BtnLink}" Click="ViewRow_Click" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Xem báo giá" FontSize="12"/>
                                                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="4,2,0,0"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource BtnIconDanger}" ToolTip="Xóa toàn bộ báo giá"
                                                            Margin="10,0,0,0" Click="DeleteRow_Click">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="Không có nhà cung cấp nào khớp tìm kiếm."
                                       Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                        </Grid>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ================= TRANG CHI TIẾT (1 NCC) ================= -->
        <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
