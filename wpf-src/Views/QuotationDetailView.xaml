<UserControl x:Class="WoodInventory.Views.QuotationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>
        <!-- Ô số bên trong khung "đơn giá + đơn vị tiền tệ" ghép — không viền/nền riêng, khung ngoài (Border) lo phần đó -->
        <Style x:Key="MoneyGroupBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"
                                      Background="{TemplateBinding Background}" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dropdown chọn đơn vị (USD/VND) gắn ở cuối ô đơn giá — cùng khung ngoài, không viền/nền riêng -->
        <Style x:Key="MoneyGroupCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SelectItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press" Background="Transparent"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,22,0" IsHitTestVisible="False"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"/>
                            <Path Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource Slate400}" StrokeThickness="1.4"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,10,0" IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" PopupAnimation="Fade" Focusable="False">
                                <Border Background="White" BorderBrush="{StaticResource Slate200}"
                                        BorderThickness="1" CornerRadius="8" Margin="0,4,0,8" MinWidth="76">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.12" Color="#0F172A"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Chip radio 3 chế độ nhập Đơn lẻ/Khoảng/Nhiều — đặt cạnh label mỗi field kích thước -->
        <Style x:Key="DimModeChip" TargetType="RadioButton">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Slate500}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" CornerRadius="5" Padding="7,3" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource Blue500}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề + quay lại + nút thêm -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BtnLink}" Click="BtnBack_Click" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,4,0"/>
                                <TextBlock Text="{helpers:Loc Common.BackLink}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleName" Text="Báo giá" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="Subtitle" FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnToggleAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock Text="{helpers:Loc Quotations.AddButton}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Form thêm/sửa/xem báo giá ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24" Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="{helpers:Loc Quotations.Form.AddTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <TextBlock Text="{helpers:Loc Quotations.Hint}"
                               FontSize="11" Foreground="{StaticResource Slate500}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Quotations.Field.WoodType}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FWoodType" Style="{StaticResource Select}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Quotations.Field.SubType}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FWoodSubType" Style="{StaticResource Select}"/>
                            <TextBlock x:Name="WSubType" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Quotations.Field.Origin}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FOrigin" Style="{StaticResource Input}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14" VerticalAlignment="Top">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblThickness" Grid.Column="0" Text="{helpers:Loc Quotations.Field.ThicknessMm}" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{StaticResource Slate100}" CornerRadius="6" Padding="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="FThickModeSingle" GroupName="ThickMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Single}" Checked="ThicknessMode_Changed"/>
                                        <RadioButton x:Name="FThickModeRange" GroupName="ThickMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Range}" Checked="ThicknessMode_Changed"/>
                                        <RadioButton x:Name="FThickModeMulti" GroupName="ThickMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Multi}" Checked="ThicknessMode_Changed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FThickMin" Grid.Column="0" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WThickRange}" TextChanged="Field_Changed"/>
                                <!-- Hint (placeholder): nội dung do code đặt theo CHIP đang chọn — xem ApplyDim() -->
                                <TextBlock x:Name="FThickMinHint" Grid.Column="0" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                                <TextBlock x:Name="FThickSep" Grid.Column="1" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Slate400}"/>
                                <TextBox x:Name="FThickMax" Grid.Column="2" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WThickRange}" TextChanged="Field_Changed"/>
                                <TextBlock x:Name="FThickMaxHint" Grid.Column="2" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="WThickRange" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14" VerticalAlignment="Top">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{helpers:Loc Quotations.Field.Width}" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{StaticResource Slate100}" CornerRadius="6" Padding="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="FWidthModeSingle" GroupName="WidthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Single}" Checked="WidthMode_Changed"/>
                                        <RadioButton x:Name="FWidthModeRange" GroupName="WidthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Range}" Checked="WidthMode_Changed"/>
                                        <RadioButton x:Name="FWidthModeMulti" GroupName="WidthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Multi}" Checked="WidthMode_Changed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FWidthMin" Grid.Column="0" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WWidthRange}" TextChanged="Field_Changed"/>
                                <TextBlock x:Name="FWidthMinHint" Grid.Column="0" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                                <TextBlock x:Name="FWidthSep" Grid.Column="1" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Slate400}"/>
                                <TextBox x:Name="FWidthMax" Grid.Column="2" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WWidthRange}" TextChanged="Field_Changed"/>
                                <TextBlock x:Name="FWidthMaxHint" Grid.Column="2" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="WWidthRange" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,14" VerticalAlignment="Top">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{helpers:Loc Quotations.Field.Length}" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{StaticResource Slate100}" CornerRadius="6" Padding="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="FLengthModeSingle" GroupName="LengthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Single}" Checked="LengthMode_Changed"/>
                                        <RadioButton x:Name="FLengthModeRange" GroupName="LengthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Range}" Checked="LengthMode_Changed"/>
                                        <RadioButton x:Name="FLengthModeMulti" GroupName="LengthMode" Style="{StaticResource DimModeChip}" Content="{helpers:Loc Quotations.Mode.Multi}" Checked="LengthMode_Changed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FLengthMin" Grid.Column="0" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WLengthRange}" TextChanged="Field_Changed"/>
                                <TextBlock x:Name="FLengthMinHint" Grid.Column="0" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                                <TextBlock x:Name="FLengthSep" Grid.Column="1" Text="–" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Slate400}"/>
                                <TextBox x:Name="FLengthMax" Grid.Column="2" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                         Tag="{Binding ElementName=WLengthRange}" TextChanged="Field_Changed"/>
                                <TextBlock x:Name="FLengthMaxHint" Grid.Column="2" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate400}" Margin="10,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="WLengthRange" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Quotations.Field.Price}" Style="{StaticResource FieldLabel}"/>
                            <Border x:Name="PriceInputBorder" BorderBrush="{StaticResource Slate200}" BorderThickness="1"
                                    CornerRadius="8" Background="White" Height="40">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FPrice" Grid.Column="0" Style="{StaticResource MoneyGroupBox}"
                                             Tag="{Binding ElementName=WPrice}" TextChanged="Field_Changed"
                                             GotFocus="PriceInput_GotFocus" LostFocus="PriceInput_LostFocus"/>
                                    <Border Grid.Column="1" Width="1" Margin="0,8" Background="{StaticResource Slate200}"/>
                                    <ComboBox x:Name="FPriceCurrency" Grid.Column="1" Width="80" Margin="1,0,0,0"
                                              Style="{StaticResource MoneyGroupCombo}" SelectedIndex="0">
                                        <ComboBoxItem Content="USD" Tag="USD"/>
                                        <ComboBoxItem Content="VND" Tag="VND"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="WPrice" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Quotations.Field.Spec}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FSpec" Style="{StaticResource Input}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="{helpers:Loc Common.Cancel}" Click="BtnCancelAdd_Click"/>
                        <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="{helpers:Loc Quotations.SaveButton}"
                                Margin="8,0,0,0" Click="BtnSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="{helpers:Loc Quotations.SearchHint}" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                        Click="BtnToggleColumnFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                        Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
            <Border x:Name="ColumnFilterPanel" Background="{StaticResource Slate50}"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,16" Visibility="Collapsed">
                <UniformGrid Columns="5" Rows="2">
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.WoodType}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FilterWoodType" Style="{StaticResource Select}" SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Thickness}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FThicknessFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Width}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FWidthColFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Length}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FLengthColFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Origin}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FOriginFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Spec}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FSpecFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Price}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FPriceFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Currency}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FilterCurrency" Style="{StaticResource Select}" SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Quotations.Filter.Updated}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FUpdatedFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Bảng báo giá (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{helpers:Loc Quotations.TotalCount}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- THỬ NGHIỆM: data cuộn ngang bên trái (*), cột thao tác tách riêng ghim phải (Auto) -->
                        <DataGrid x:Name="ItemGrid" Grid.Column="0" Style="{StaticResource DataTable}" CanUserSortColumns="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.WoodType}" Binding="{Binding WoodTypeDisplay}" Width="200" MinWidth="200" SortMemberPath="WoodType">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.Thickness}" Binding="{Binding ThicknessText}" Width="190" MinWidth="190" SortMemberPath="ThicknessMin">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.Width}" Binding="{Binding WidthText}" Width="190" MinWidth="190" SortMemberPath="WidthMin">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.Length}" Binding="{Binding LengthText}" Width="190" MinWidth="190" SortMemberPath="LengthMin">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Origin}" Binding="{Binding OriginText}" Width="120" MinWidth="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.Spec}" Binding="{Binding Specification}" Width="160" MinWidth="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Column.Price}" Binding="{Binding PriceText}" Width="150" MinWidth="130" SortMemberPath="Price">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Currency}" Binding="{Binding PriceCurrency}" Width="90" MinWidth="90" SortMemberPath="PriceCurrency">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Quotations.Filter.Updated}" Binding="{Binding UpdatedAtText}" Width="180" MinWidth="170" SortMemberPath="Updated">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate500}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Cột thao tác tách riêng: bind cùng nguồn _view, cuộn dọc đồng bộ theo ItemGrid qua GridPairSync -->
                        <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}"
                                  BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{helpers:Loc Common.Column.Actions}" Width="120" MinWidth="120"
                                                        CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnIcon}" ToolTip="{helpers:Loc Common.Tooltip.View}" Click="ViewRow_Click">
                                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Style="{StaticResource BtnIconDanger}" ToolTip="{helpers:Loc Quotations.Tooltip.Delete}"
                                                        Margin="8,0,0,0" Click="DeleteRow_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="{helpers:Loc Quotations.Empty}"
                                   Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
