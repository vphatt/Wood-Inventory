<UserControl x:Class="WoodInventory.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="{helpers:Loc Suppliers.Title}" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnToggleAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock Text="{helpers:Loc Suppliers.AddButton}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Form thêm/sửa (ẩn/hiện, đẩy bảng xuống) ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="{helpers:Loc Suppliers.Form.AddTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Hàng 1 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.Name}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FName" Style="{StaticResource Input}" Tag="{Binding ElementName=WName}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WName" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.Code}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FCode" Style="{StaticResource Input}" Tag="{Binding ElementName=WCode}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WCode" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>

                        <!-- Hàng 2 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.TaxCode}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FTaxCode" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"
                                     Tag="{Binding ElementName=WTaxCode}" TextChanged="Field_Changed"/>
                            <TextBlock x:Name="WTaxCode" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.Address}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FAddress" Style="{StaticResource Input}"/>
                        </StackPanel>

                        <!-- Hàng 3 -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.Phone}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FPhone" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="{helpers:Loc Suppliers.Field.BankAccount}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FBankAccount" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="{helpers:Loc Common.Cancel}" Click="BtnCancelAdd_Click"/>
                        <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="{helpers:Loc Suppliers.SaveButton}"
                                Margin="8,0,0,0" Click="BtnSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="360">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="{helpers:Loc Suppliers.SearchHint}" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                        Click="BtnToggleColumnFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                        Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
            <Border x:Name="ColumnFilterPanel" Background="{StaticResource Slate50}"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,16" Visibility="Collapsed">
                <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Suppliers.Column.Name}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FNameFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Suppliers.Column.TaxCode}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FTaxCodeFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc Suppliers.Field.Address}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FAddressFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Bảng danh sách nhà cung cấp (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{helpers:Loc Suppliers.TotalCount}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="Grid" Grid.Column="0" Style="{StaticResource DataTable}" RowHeight="46" CanUserSortColumns="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="{helpers:Loc Suppliers.Column.Name}" SortMemberPath="Name" Width="300" MinWidth="300">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Slate800}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CodeLabel}" FontSize="10"
                                                           Foreground="{StaticResource Slate400}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="{helpers:Loc Suppliers.Column.TaxCode}" Binding="{Binding TaxCode}" Width="180" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="{helpers:Loc Suppliers.Field.Address}" Binding="{Binding Address}" Width="240" MinWidth="240">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn _view. RowHeight=46 khớp grid data cho thẳng hàng -->
                        <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}" RowHeight="46"
                                  BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{helpers:Loc Common.Column.Actions}" Width="290" MinWidth="290"
                                                        CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnLink}" ToolTip="{helpers:Loc Suppliers.Tooltip.ViewQuote}"
                                                        Click="OpenQuotation_Click" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding QuoteButtonText}" FontSize="12"/>
                                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="4,2,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource BtnIcon}" ToolTip="{helpers:Loc Common.Tooltip.View}"
                                                        Margin="12,0,0,0" Click="ViewRow_Click">
                                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Style="{StaticResource BtnIconDanger}" ToolTip="{helpers:Loc Suppliers.Tooltip.Delete}"
                                                        Margin="8,0,0,0" Click="DeleteRow_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="{helpers:Loc Suppliers.Empty}"
                                   Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
        <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
