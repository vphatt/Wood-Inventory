<UserControl x:Class="WoodInventory.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Bảng Điều Hành Trung Tâm (Quản Lý Gỗ)" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Phân tích dòng chảy gỗ, giá trị tồn kho và tình trạng vận hành theo thời gian thực."
                               FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,3,0,0"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="White"
                        BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="4" Padding="12,5">
                    <TextBlock Text="Phiên bản ERP: v1.0.0 (WPF Native)" FontFamily="{StaticResource FontMono}"
                               FontSize="11" Foreground="{StaticResource Slate400}"/>
                </Border>
            </Grid>

            <!-- 4 thẻ KPI -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- KPI 1: Thể tích tồn kho -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="THỂ TÍCH TỒN KHO" FontSize="10.5" FontWeight="Medium"
                                       Foreground="{StaticResource Slate400}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                                <TextBlock x:Name="KpiVolume" Text="0.0000" FontSize="23" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Slate800}"/>
                                <TextBlock Text=" m³" FontSize="11" Foreground="{StaticResource Slate400}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="Sẵn sàng sản xuất" FontSize="10" FontWeight="Medium"
                                       Foreground="{StaticResource Emerald600}"/>
                        </StackPanel>
                        <Border Width="46" Height="46" CornerRadius="8" Background="{StaticResource Blue50}"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Blue600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- KPI 2: Giá trị tồn kho -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="GIÁ TRỊ TỒN KHO" FontSize="10.5" FontWeight="Medium"
                                       Foreground="{StaticResource Slate400}"/>
                            <TextBlock x:Name="KpiValue" Text="0 ₫" FontSize="19" FontWeight="Bold"
                                       FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Slate800}"
                                       Margin="0,8,0,6"/>
                            <TextBlock Text="Tính theo giá vốn đã gồm thuế" FontSize="10"
                                       Foreground="{StaticResource Slate400}"/>
                        </StackPanel>
                        <Border Width="46" Height="46" CornerRadius="8" Background="{StaticResource Emerald50}"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="$" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource Emerald600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- KPI 3: Tổng số kiện -->
                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TỔNG SỐ KIỆN GỖ (LOTS)" FontSize="10.5" FontWeight="Medium"
                                       Foreground="{StaticResource Slate400}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                                <TextBlock x:Name="KpiLots" Text="0" FontSize="23" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Slate800}"/>
                                <TextBlock Text=" kiện" FontSize="11" Foreground="{StaticResource Slate400}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="Được quản lý theo Lot ID" FontSize="10" FontWeight="Medium"
                                       Foreground="{StaticResource Blue500}"/>
                        </StackPanel>
                        <Border Width="46" Height="46" CornerRadius="8" Background="{StaticResource Indigo50}"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="↙" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource Indigo600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- KPI 4: Cảnh báo tồn thấp -->
                <Border Grid.Column="6" Style="{StaticResource Card}" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="CẢNH BÁO TỒN THẤP" FontSize="10.5" FontWeight="Medium"
                                       Foreground="{StaticResource Slate400}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                                <TextBlock x:Name="KpiLowStock" Text="0" FontSize="23" FontWeight="Bold"
                                           FontFamily="{StaticResource FontMono}" Foreground="{StaticResource Rose600}"/>
                                <TextBlock Text=" kiện" FontSize="11" Foreground="{StaticResource Rose400}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                            <TextBlock Text="Cần lên kế hoạch mua thêm" FontSize="10" FontWeight="Medium"
                                       Foreground="{StaticResource Rose500}"/>
                        </StackPanel>
                        <Border Width="46" Height="46" CornerRadius="8" Background="{StaticResource Rose50}"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Rose600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3 khối phân tích -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tỷ lệ tồn kho theo chủng loại -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20" MinHeight="220">
                    <StackPanel>
                        <TextBlock Text="Tỷ lệ tồn kho theo chủng loại" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Slate800}" Padding="0,0,0,8"/>
                        <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,14"/>
                        <ItemsControl x:Name="WoodTypeBars">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12">
                                        <Grid Margin="0,0,0,5">
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource Slate700}"/>
                                            <TextBlock Text="{Binding ValueText}" FontSize="11"
                                                       FontFamily="{StaticResource FontMono}"
                                                       Foreground="{StaticResource Slate500}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource MiniBar}" Value="{Binding Percent, Mode=OneWay}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Giá trị nhập theo nhà cung cấp -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20" MinHeight="220">
                    <StackPanel>
                        <TextBlock Text="Giá trị nhập theo nhà cung cấp" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Slate800}" Padding="0,0,0,8"/>
                        <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,14"/>
                        <ItemsControl x:Name="SupplierBars">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Slate700}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ValueText}" FontSize="10"
                                                       FontFamily="{StaticResource FontMono}"
                                                       Foreground="{StaticResource Slate400}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ProgressBar Grid.Column="1" Width="96" Height="10" VerticalAlignment="Center"
                                                     Style="{StaticResource MiniBar}"
                                                     Foreground="{StaticResource Emerald500}"
                                                     Value="{Binding Percent, Mode=OneWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Kiện gỗ sắp hết -->
                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20" MinHeight="220">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Kiện gỗ sắp hết (Low-Stock)" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource Slate800}"/>
                            <Button x:Name="BtnGoLots" Style="{StaticResource BtnLink}" HorizontalAlignment="Right"
                                    Click="BtnGoLots_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Xem chi tiết" FontSize="12"/>
                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="4,2,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,14"/>
                        <TextBlock x:Name="LowStockEmpty" Text="Tuyệt vời! Không có kiện gỗ nào dưới định mức cảnh báo."
                                   FontSize="12" Foreground="{StaticResource Slate400}"
                                   HorizontalAlignment="Center" Margin="0,28" TextWrapping="Wrap" TextAlignment="Center"/>
                        <ItemsControl x:Name="LowStockList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate150}"
                                            BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold"
                                                           Foreground="{StaticResource Slate700}"/>
                                                <TextBlock Text="{Binding Meta}" FontSize="10"
                                                           Foreground="{StaticResource Slate400}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding QtyText}" FontSize="12" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource Rose600}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding CbmText}" FontSize="10"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource Slate400}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Thao tác nhanh -->
            <Border Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Thao tác nghiệp vụ nhanh (Odoo Inspired Keyboard Optimized)"
                               FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Slate800}"
                               Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" x:Name="QuickReceipts" Style="{StaticResource Card}"
                                CornerRadius="8" Padding="12" Cursor="Hand"
                                MouseLeftButtonDown="QuickReceipts_Click">
                            <Grid>
                                <StackPanel Margin="0,0,22,0">
                                    <TextBlock Text="Nhập Kho Kiện Mới" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Slate700}"/>
                                    <TextBlock Text="Khởi tạo phiếu và tra giá tự động" FontSize="10"
                                               Foreground="{StaticResource Slate400}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Text="↙" FontSize="15" Foreground="{StaticResource Slate400}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" x:Name="QuickIssues" Style="{StaticResource Card}"
                                CornerRadius="8" Padding="12" Cursor="Hand"
                                MouseLeftButtonDown="QuickIssues_Click">
                            <Grid>
                                <StackPanel Margin="0,0,22,0">
                                    <TextBlock Text="Xuất Kho Gỗ Sản Xuất" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Slate700}"/>
                                    <TextBlock Text="Xuất gỗ từ các kiện theo Đơn hàng" FontSize="10"
                                               Foreground="{StaticResource Slate400}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Text="↗" FontSize="15" Foreground="{StaticResource Slate400}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="4" x:Name="QuickQuotations" Style="{StaticResource Card}"
                                CornerRadius="8" Padding="12" Cursor="Hand"
                                MouseLeftButtonDown="QuickQuotations_Click">
                            <Grid>
                                <StackPanel Margin="0,0,22,0">
                                    <TextBlock Text="Cập Nhật Báo Giá Gỗ" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Slate700}"/>
                                    <TextBlock Text="Thay đổi giá mua nguyên liệu của NCC" FontSize="10"
                                               Foreground="{StaticResource Slate400}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource Slate400}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="6" x:Name="QuickDotnet" Style="{StaticResource Card}"
                                CornerRadius="8" Padding="12" Cursor="Hand"
                                MouseLeftButtonDown="QuickDotnet_Click">
                            <Grid>
                                <StackPanel Margin="0,0,22,0">
                                    <TextBlock Text="Mã C# .NET Clean Architecture" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Slate700}"/>
                                    <TextBlock Text="Xem mã nguồn nghiệp vụ của hệ thống" FontSize="10"
                                               Foreground="{StaticResource Slate400}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{StaticResource Slate400}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
