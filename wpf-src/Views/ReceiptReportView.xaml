<UserControl x:Class="WoodInventory.Views.ReceiptReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <UserControl.Resources>
        <!-- Ô văn bản trái (tên/chứng từ) -->
        <Style x:Key="RCellL" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="RCellName" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <!-- Ô mono căn giữa -->
        <Style x:Key="RCellC" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Mã kiện / số phiếu — mono center đậm -->
        <Style x:Key="RCellId" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Slate900}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Ô mono căn phải -->
        <Style x:Key="RCellR" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RVol" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RMoney" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Emerald600}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Quay lại + tiêu đề -->
            <StackPanel Margin="0,0,0,12">
                <Button Style="{StaticResource BtnLink}" Click="BtnBack_Click" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,4,0"/>
                        <TextBlock Text="{helpers:Loc Common.BackLink}"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                    <TextBlock Text="{helpers:Loc ReceiptReport.Title}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Text="{helpers:Loc ReceiptReport.Subtitle}"
                           FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Thanh công cụ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,30,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <Button Style="{StaticResource SearchClearBtn}" helpers:ClearBox.Target="{Binding ElementName=SearchBox}"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="{helpers:Loc ReceiptReport.SearchHint}" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                        Click="BtnToggleColumnFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                        Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
            <Border x:Name="ColumnFilterPanel" Background="{StaticResource Slate50}"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,16" Visibility="Collapsed">
                <UniformGrid Columns="6" Rows="5">
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Filter.Id}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FReceiptIdFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Field.Supplier}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FilterSupplier" Style="{StaticResource Select}" SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Field.Date}" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="FImportDateFilter" Style="{StaticResource DatePickerField}" SelectedDateChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Invoice}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FInvoiceFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Field.ForestList}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FForestListFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{helpers:Loc Receipts.Field.PackingList}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FPackingListFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.LotId}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FIdFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.DeliveryNote}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FDeliveryNoteFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.WoodType}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FWoodTypeFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.SubType}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FSubTypeFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Origin}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FOriginFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Grade}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FGradeFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Thickness}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FDayFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Width}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FWidthFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Length}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FLengthFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Footage}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FFootageFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Qty}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FQtyFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Vol}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FVolFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc Receipts.Column.Price}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FPriceFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Currency}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FCurrencyFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.ExRate}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FExRateFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Tax}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FTaxFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Subtotal}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FSubtotalFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,12">
                        <TextBlock Text="{helpers:Loc ReceiptReport.Filter.Vat}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FVatFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="{helpers:Loc Receipts.Column.GrandTotal}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FTotalFilter" Style="{StaticResource Input}" FontFamily="{StaticResource FontMono}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- Bảng -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <!-- Footer tổng -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{helpers:Loc ReceiptReport.Totals.Lots}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalLots" Text="0 kiện" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{helpers:Loc ReceiptReport.Totals.Qty}" Foreground="{StaticResource Slate500}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalQty" Text="0 thanh" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{helpers:Loc ReceiptReport.Totals.Vol}" Foreground="{StaticResource Slate500}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalVol" Text="0,0000 m³" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Blue600}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{helpers:Loc ReceiptReport.Totals.Val}" Foreground="{StaticResource Slate500}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalVal" Text="0 ₫" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Emerald600}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <DataGrid x:Name="ReportGrid" Style="{StaticResource DataTable}" RowHeight="40" MinRowHeight="40" MaxHeight="700">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="60" MinWidth="60" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(helpers:RowNumbering.Number)}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                            <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Filter.Id}" Binding="{Binding ReceiptId}" Width="118" MinWidth="118" ElementStyle="{StaticResource RCellId}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Field.Supplier}" Binding="{Binding SupplierName}" Width="230" MinWidth="230" ElementStyle="{StaticResource RCellName}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Field.Date}" Binding="{Binding ImportDateText}" Width="130" MinWidth="130" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Invoice}" Binding="{Binding InvoiceText}" Width="120" MinWidth="120" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Field.ForestList}" Binding="{Binding ForestListText}" Width="150" MinWidth="150" ElementStyle="{StaticResource RCellL}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Field.PackingList}" Binding="{Binding PackingListText}" Width="130" MinWidth="130" ElementStyle="{StaticResource RCellL}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.LotId}" Binding="{Binding Id}" Width="110" MinWidth="110" ElementStyle="{StaticResource RCellId}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.DeliveryNote}" Binding="{Binding DeliveryNoteText}" Width="140" MinWidth="140" ElementStyle="{StaticResource RCellL}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.WoodType}" Binding="{Binding WoodTypeText}" Width="120" MinWidth="120" ElementStyle="{StaticResource RCellName}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.SubType}" Binding="{Binding SubTypeText}" Width="120" MinWidth="120" ElementStyle="{StaticResource RCellL}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Origin}" Binding="{Binding OriginText}" Width="90" MinWidth="90" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Grade}" Binding="{Binding GradeText}" Width="90" MinWidth="90" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Thickness}" Binding="{Binding DayText}" Width="76" MinWidth="76" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Width}" Binding="{Binding WidthText}" Width="76" MinWidth="76" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Length}" Binding="{Binding LengthText}" Width="110" MinWidth="110" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Footage}" Binding="{Binding FootageText}" Width="92" MinWidth="92" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Qty}" Binding="{Binding QtyText}" Width="120" MinWidth="120" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Vol}" Binding="{Binding VolText}" Width="120" MinWidth="120" ElementStyle="{StaticResource RVol}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.Price}" Binding="{Binding PriceText}" Width="100" MinWidth="100" ElementStyle="{StaticResource RCellR}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Currency}" Binding="{Binding CurrencyText}" Width="70" MinWidth="70" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.ExRate}" Binding="{Binding ExRateText}" Width="90" MinWidth="90" ElementStyle="{StaticResource RCellR}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Tax}" Binding="{Binding TaxText}" Width="80" MinWidth="80" ElementStyle="{StaticResource RCellC}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Subtotal}" Binding="{Binding SubtotalText}" Width="140" MinWidth="140" ElementStyle="{StaticResource RCellR}"/>
                                <DataGridTextColumn Header="{helpers:Loc ReceiptReport.Filter.Vat}" Binding="{Binding VatText}" Width="130" MinWidth="130" ElementStyle="{StaticResource RCellR}"/>
                                <DataGridTextColumn Header="{helpers:Loc Receipts.Column.GrandTotal}" Binding="{Binding TotalText}" Width="150" MinWidth="150" ElementStyle="{StaticResource RMoney}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="EmptyRow" Text="{helpers:Loc ReceiptReport.Empty}"
                                   Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
