<UserControl x:Class="WoodInventory.Views.WoodCategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="Quản Lý Phân Loại Gỗ" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Danh mục loại gỗ và nguyên tắc tính thể tích m³. Quyết định trường bắt buộc khi nhập/xuất kho."
                               FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnToggleAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock Text="Thêm loại gỗ"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Form thêm loại gỗ (ẩn/hiện, đẩy bảng xuống) ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="Khai Báo Loại Gỗ Mới" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="TÊN LOẠI GỖ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FName" Style="{StaticResource Input}" TextChanged="FName_Changed"/>
                            <TextBlock x:Name="WName" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NGUYÊN TẮC TÍNH M³" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FRule" Style="{StaticResource Select}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chú thích ràng buộc theo nguyên tắc -->
                    <Border Background="#80EFF6FF" BorderBrush="{StaticResource Blue100}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource Blue800}" VerticalAlignment="Top" Margin="0,1,10,0"/>
                            <TextBlock x:Name="RuleHint" TextWrapping="Wrap" Foreground="{StaticResource Blue800}"
                                       MaxWidth="600" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="Hủy bỏ" Click="BtnCancelAdd_Click"/>
                        <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="Lưu loại gỗ"
                                Margin="8,0,0,0" Click="BtnSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,10,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="Tìm tên loại gỗ..." FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <ComboBox x:Name="FilterRule" Style="{StaticResource Select}" MinWidth="220"
                          Margin="12,0,0,0" SelectionChanged="Filter_Changed"/>
            </StackPanel>

            <!-- ===== Bảng danh mục loại gỗ (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <!-- Footer -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tổng số loại gỗ:" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="Grid" Grid.Column="0" Style="{StaticResource DataTable}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STT" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=AlternationIndex, Converter={StaticResource RowNumberConverter}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="TÊN LOẠI GỖ" Binding="{Binding Name}" Width="*" MinWidth="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="NGUYÊN TẮC TÍNH M³" SortMemberPath="RuleLabel" Width="380" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="badge" CornerRadius="999" Padding="10,3" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" Background="{StaticResource Blue50}">
                                                <TextBlock x:Name="badgeText" Text="{Binding RuleLabel}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Blue700}"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsFootage}" Value="True">
                                                    <Setter TargetName="badge" Property="Background" Value="{StaticResource Indigo50}"/>
                                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource Indigo600}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="PHÂN LOẠI CON" Width="200" MinWidth="150" SortMemberPath="SubCount">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource BtnLink}" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" ToolTip="Quản lý phân loại con"
                                                    Click="OpenSubs_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,6,0"/>
                                                    <TextBlock Text="{Binding SubCountText}"/>
                                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,1,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                        <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}"
                                  BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="THAO TÁC" Width="120" MinWidth="120"
                                                        CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnIcon}" ToolTip="Xem chi tiết" Click="ViewRow_Click">
                                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Style="{StaticResource BtnIconDanger}" ToolTip="Xóa loại gỗ"
                                                        Margin="8,0,0,0" Click="DeleteRow_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="Không có loại gỗ nào khớp bộ lọc."
                                   Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
        <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
