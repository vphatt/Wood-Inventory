<UserControl x:Class="WoodInventory.Views.WoodCategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <ScrollViewer x:Name="ListRoot" VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Tiêu đề + nút -->
            <Grid Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock Text="{helpers:Loc WoodCategories.Title}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnToggleAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock Text="{helpers:Loc WoodCategories.AddButton}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Form thêm loại gỗ (ẩn/hiện, đẩy bảng xuống) ===== -->
            <Border x:Name="AddFormPanel" Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24"
                    Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="FormTitle" Text="{helpers:Loc WoodCategories.Form.AddTitle}" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource Slate100}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="{helpers:Loc WoodCategories.Field.Name}" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FName" Style="{StaticResource Input}" TextChanged="FName_Changed"/>
                            <TextBlock x:Name="WName" Style="{StaticResource FieldWarn}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{helpers:Loc WoodCategories.Field.Rule}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FRule" Style="{StaticResource Select}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chú thích ràng buộc theo nguyên tắc -->
                    <Border Background="#80EFF6FF" BorderBrush="{StaticResource Blue100}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource Blue800}" VerticalAlignment="Top" Margin="0,1,10,0"/>
                            <TextBlock x:Name="RuleHint" TextWrapping="Wrap" Foreground="{StaticResource Blue800}"
                                       MaxWidth="600" LineHeight="18"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="FormCancelBtn" Style="{StaticResource BtnGhost}" Content="{helpers:Loc Common.Cancel}" Click="BtnCancelAdd_Click"/>
                        <Button x:Name="FormSaveBtn" Style="{StaticResource BtnPrimary}" Content="{helpers:Loc WoodCategories.SaveButton}"
                                Margin="8,0,0,0" Click="BtnSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Thanh tìm kiếm + lọc ===== -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Grid Width="300">
                    <TextBox x:Name="SearchBox" Style="{StaticResource Input}" Padding="30,6,30,6"
                             Background="White" TextChanged="Filter_Changed"/>
                    <Button Style="{StaticResource SearchClearBtn}" helpers:ClearBox.Target="{Binding ElementName=SearchBox}"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="11,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <TextBlock x:Name="SearchHint" Text="{helpers:Loc WoodCategories.SearchHint}" FontSize="12"
                               Foreground="{StaticResource Slate400}" Margin="31,0,0,0"
                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
                <Button x:Name="BtnToggleColumnFilters" Style="{StaticResource BtnGhost}" Margin="12,0,0,0"
                        Click="BtnToggleColumnFilters_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,1,6,0"/>
                        <TextBlock x:Name="ToggleColumnFiltersLabel" Text="{helpers:Loc Common.FilterByColumn}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnClearColumnFilters" Style="{StaticResource BtnLink}" Margin="12,0,0,0"
                        Content="{helpers:Loc Common.ClearColumnFilter}" Click="BtnClearColumnFilters_Click" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Bộ lọc theo từng cột (thu gọn mặc định) -->
            <Border x:Name="ColumnFilterPanel" Background="{StaticResource Slate50}"
                    BorderBrush="{StaticResource Slate200}" BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,16" Visibility="Collapsed">
                <UniformGrid Columns="3">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc WoodCategories.Field.Name}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FNameFilter" Style="{StaticResource Input}" TextChanged="Filter_Changed"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{helpers:Loc WoodCategories.Field.Rule}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="FilterRule" Style="{StaticResource Select}" SelectionChanged="Filter_Changed"/>
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Bảng danh mục loại gỗ (DataGrid tương tác) ===== -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <!-- Footer -->
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{helpers:Loc WoodCategories.TotalCount}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="Grid" Grid.Column="0" Style="{StaticResource DataTable}" CanUserSortColumns="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="50" MinWidth="50" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(helpers:RowNumbering.Number)}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                            <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{helpers:Loc WoodCategories.Field.Name}" Binding="{Binding Name}" Width="180" MinWidth="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource Slate800}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="{helpers:Loc WoodCategories.Field.Rule}" SortMemberPath="RuleLabel" Width="380" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="badge" CornerRadius="999" Padding="10,3" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" Background="{StaticResource Blue50}">
                                                <TextBlock x:Name="badgeText" Text="{Binding RuleLabel}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Blue700}"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsFootage}" Value="True">
                                                    <Setter TargetName="badge" Property="Background" Value="{StaticResource Indigo50}"/>
                                                    <Setter TargetName="badgeText" Property="Foreground" Value="{StaticResource Indigo600}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{helpers:Loc WoodCategories.Column.SubCategory}" Width="200" MinWidth="150" SortMemberPath="SubCount">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource BtnLink}" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" ToolTip="{helpers:Loc WoodCategories.Tooltip.ManageSubs}"
                                                    Click="OpenSubs_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,6,0"/>
                                                    <TextBlock Text="{Binding SubCountText}"/>
                                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="6,1,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Cột thao tác tách riêng, ghim phải, cùng nguồn -->
                        <DataGrid x:Name="ActionGrid" Grid.Column="1" Style="{StaticResource DataTable}"
                                  BorderThickness="1,0,0,0" BorderBrush="{StaticResource Slate200}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{helpers:Loc Common.Column.Actions}" Width="120" MinWidth="120"
                                                        CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnIcon}" ToolTip="{helpers:Loc Common.Tooltip.View}" Click="ViewRow_Click">
                                                    <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Style="{StaticResource BtnIconDanger}" ToolTip="{helpers:Loc WoodCategories.Tooltip.Delete}"
                                                        Margin="8,0,0,0" Click="DeleteRow_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="EmptyRow" Grid.ColumnSpan="2" Text="{helpers:Loc WoodCategories.Empty}"
                                   Foreground="{StaticResource Slate400}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,60" Visibility="Collapsed"/>
                    </Grid>
                </DockPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
        <ContentControl x:Name="DetailHost" Visibility="Collapsed"/>
    </Grid>
</UserControl>
