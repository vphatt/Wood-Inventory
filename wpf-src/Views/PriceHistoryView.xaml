<UserControl x:Class="WoodInventory.Views.PriceHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:WoodInventory.Helpers"
             FontFamily="Segoe UI" FontSize="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Slate50}">
        <StackPanel Margin="24">

            <!-- Quay lại + tiêu đề -->
            <Button Style="{StaticResource BtnLink}" Click="BtnBack_Click" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,1,4,0"/>
                    <TextBlock Text="{helpers:Loc Common.BackLink}"/>
                </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource Blue500}" VerticalAlignment="Center"/>
                <TextBlock Text="{helpers:Loc Quotations.PriceHistory.Title}" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource Slate800}" Margin="8,0,0,0"/>
            </StackPanel>
            <TextBlock x:Name="Subtitle" FontSize="12" Foreground="{StaticResource Slate500}" Margin="0,0,0,16"/>

            <!-- Thông tin dòng báo giá (giống viewmode) -->
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{helpers:Loc Quotations.PriceHistory.ItemInfo}" FontWeight="SemiBold"
                               Foreground="{StaticResource Slate800}" Margin="0,0,0,14"/>
                    <UniformGrid x:Name="InfoPanel" Columns="4"/>
                </StackPanel>
            </Border>

            <!-- Bảng lịch sử thay đổi giá (chỉ đọc) -->
            <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource Slate50}" BorderBrush="{StaticResource Slate200}"
                            BorderThickness="0,1,0,0" Padding="24,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{helpers:Loc Quotations.PriceHistory.TotalCount}" Foreground="{StaticResource Slate500}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalCount" Text="0" FontWeight="Bold" FontFamily="{StaticResource FontMono}"
                                       Foreground="{StaticResource Slate800}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="HistoryGrid" Style="{StaticResource DataTable}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{helpers:Loc Common.Column.Stt}" Width="60" MinWidth="60" IsReadOnly="True" CanUserReorder="False" CanUserSort="False"
                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(helpers:RowNumbering.Number)}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="Foreground" Value="{StaticResource Slate400}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{helpers:Loc Quotations.PriceHistory.Column.Time}" Binding="{Binding TimeText}" Width="220" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Slate600}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{helpers:Loc Quotations.PriceHistory.Column.Price}" Binding="{Binding PriceText}" Width="200" MinWidth="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Blue700}"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{helpers:Loc Quotations.PriceHistory.Column.Reason}" Binding="{Binding ReasonText}" Width="360" MinWidth="300">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="Foreground" Value="{StaticResource Slate700}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding ReasonText}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
